# .env.example — Copie este arquivo para .env e preencha os valores.
# Comando: cp .env.example .env

# ==============================================================
# BANCO DE DADOS
# ==============================================================

# Caminho do arquivo SQLite dentro do container
DATABASE_PATH=/app/data/isyshell.db

# ==============================================================
# SCRIPTS
# ==============================================================

# Pasta onde os scripts .sh ficam dentro do container
SCRIPTS_PATH=/scripts

# ==============================================================
# STRIPE (necessário apenas para pagamentos / upgrade de plano)
# ==============================================================

# Segredo do webhook — encontre em: Stripe → Developers → Webhooks → seu endpoint
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_AQUI

# IDs dos preços dos planos — encontre em: Stripe → Products → seu produto → Prices
STRIPE_PRICE_PRO=price_COLOQUE_AQUI
STRIPE_PRICE_ENTERPRISE=price_COLOQUE_AQUI
